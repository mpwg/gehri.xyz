---
import { getEntry } from 'astro:content';
import SiteLayout from '../layouts/SiteLayout.astro';

const page = await getEntry('site', 'homepage');
if (!page) {
  throw new Error('Content entry "homepage" not found in site collection');
}

const {
  title,
  description,
  hero,
  about,
  contact,
  projects,
  profileImageAlt,
} = page.data;
---

<SiteLayout title={title} description={description}>
  <header class="site-header">
    <div class="brand">Matthias Géhri</div>
    <nav aria-label="Hauptnavigation">
      <a href="#ueber-mich">Über mich</a>
      <a href="#kontakt">Kontakt</a>
      <a href="#projekte">Projekte</a>
    </nav>
  </header>

  <main class="page-shell">
    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">{hero.eyebrow}</p>
        <h1>{hero.headline}</h1>
        <p class="lede">{hero.intro}</p>
        <div class="hero-actions">
          <a class="button button-primary" href="#kontakt">{hero.primaryCtaLabel}</a>
          <a class="button button-secondary" href="#projekte">{hero.secondaryCtaLabel}</a>
        </div>
      </div>
      <div class="portrait-wrap">
        <img
          class="portrait"
          src="/profile.png"
          alt={profileImageAlt}
          width="1024"
          height="1024"
        />
      </div>
    </section>

    <section id="ueber-mich" class="panel about">
      <div class="section-head">
        <p class="section-tag">Über mich</p>
        <h2>{about.title}</h2>
      </div>
      <div class="about-grid">
        {about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </section>

    <section id="kontakt" class="panel contact">
      <div class="section-head">
        <p class="section-tag">Kontakt</p>
        <h2>{contact.title}</h2>
      </div>
      <div class="contact-list">
        {contact.links.map((entry) => (
          <a class="contact-card" href={entry.href} target={entry.href.startsWith('http') ? '_blank' : undefined} rel={entry.href.startsWith('http') ? 'noreferrer' : undefined}>
            <span class="contact-label">{entry.label}</span>
            <strong>{entry.handle}</strong>
          </a>
        ))}
      </div>
    </section>

    <section id="projekte" class="panel projects">
      <div class="section-head">
        <p class="section-tag">Projekte</p>
        <h2>{projects.title}</h2>
      </div>
      <div class="project-grid">
        {projects.items.map((project) => (
          <article class="project-card">
            <h3>{project.name}</h3>
            <p>{project.description}</p>
            <a href={project.href} target="_blank" rel="noreferrer">Projekt öffnen</a>
          </article>
        ))}
      </div>
    </section>
  </main>
</SiteLayout>
