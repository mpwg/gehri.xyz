---
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';

const links = [
  { href: '/', label: 'Startseite' },
  { href: '/#apps', label: 'Apps' },
];
---

<SiteLayout
  title="Migräne Tracker | Matthias Wallner-Géhri"
  description="Produktseite für die App Migräne Tracker von Matthias Wallner-Géhri"
>
  <SiteHeader brand="Matthias Wallner-Géhri" links={links} />

  <main class="page-shell app-shell">
    <section class="panel app-panel">
      <div class="section-head">
        <p class="section-tag">App</p>
        <h1>Migräne Tracker</h1>
      </div>

      <div class="app-copy">
        <p class="app-lede">
          Migräne Tracker unterstützt dabei, Migräneereignisse klar zu dokumentieren und
          Entwicklungen über die Zeit nachvollziehbar festzuhalten.
        </p>

        <div class="app-meta">
          <div class="app-meta-card">
            <span class="contact-label">Plattform</span>
            <strong>iPhone und iPad</strong>
          </div>
          <div class="app-meta-card">
            <span class="contact-label">Verfügbarkeit</span>
            <strong>App Store</strong>
          </div>
        </div>

        <section>
          <h2>Worum es geht</h2>
          <p>
            Die App ist auf einen einfachen und alltagstauglichen Ablauf ausgelegt. Statt unnötiger
            Komplexität steht im Vordergrund, Einträge schnell zu erfassen und sie später sinnvoll
            wiederzufinden.
          </p>
        </section>

        <section>
          <h2>App öffnen</h2>
          <p>
            <a
              class="button button-primary"
              href="https://apps.apple.com/at/app/migr%C3%A4ne-tracker/id6761906025"
              target="_blank"
              rel="noreferrer"
            >
              Im App Store ansehen
            </a>
          </p>
        </section>
      </div>
    </section>
  </main>

  <SiteFooter />
</SiteLayout>
