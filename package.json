{
  "name": "gehri.xyz",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "deploy": "npm run build && wrangler deploy",
    "cms-auth:deploy": "wrangler deploy --config cms-auth/wrangler.toml",
    "cms-auth:secret:id": "wrangler secret put GITHUB_OAUTH_ID --config cms-auth/wrangler.toml",
    "cms-auth:secret:secret": "wrangler secret put GITHUB_OAUTH_SECRET --config cms-auth/wrangler.toml",
    "astro": "astro",
    "ci:deploy-check": "npm run check && npm run build",
    "setup:github-deploy": "bash ./scripts/bootstrap-github-deploy.sh"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.10",
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/sitemap": "^3.7.0",
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource-variable/sora": "^5.2.8",
    "astro": "^5.18.0",
    "sharp": "^0.34.5",
    "wrangler": "^4.71.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "wrangler": "^4.71.0",
    "lodash": "^4.17.23"
  }
}
